PORTFOLIO_REDUCE_SCORE_SAME_DIRECTION=8
PORTFOLIO_REDUCE_SCORE_SAME_GROUP=15
PORTFOLIO_BLOCK_SAME_SYMBOL=true
PORTFOLIO_TOP_LIMIT=10

PORTFOLIO_CORRELATION_GROUPS=BTC:BTC_USDT;LARGE_CAP:ETH_USDT,BNB_USDT;L1_BETA:SOL_USDT,AVAX_USDT,SUI_USDT,APT_USDT,NEAR_USDT,SEI_USDT;PAYMENTS:XRP_USDT,ADA_USDT,TRX_USDT;L2:ARB_USDT,OP_USDT;MEME:DOGE_USDT;ORACLE:LINK_USDT;TON:TON_USDT;DEFI:INJ_USDT


# AI DECISION ENGINE v0.7.0
DECISION_ENGINE_ENABLED=true
DECISION_ENTER_SCORE=90
DECISION_CONFIRM_SCORE=82
DECISION_WAIT_SCORE=72

# ENTER требует явного APPROVE от OpenAI.
# CONFIRM может быть доступен без APPROVE, если общий score достаточен.
DECISION_REQUIRE_AI_FOR_ENTER=true

# false: при ошибке ИИ возможен ручной CONFIRM, но не ENTER.
DECISION_BLOCK_ON_AI_ERROR=false

DECISION_AI_APPROVE_BONUS=6
DECISION_AI_WAIT_PENALTY=6
DECISION_AI_REJECT_PENALTY=30
DECISION_TREND_REGIME_BONUS=5
DECISION_RANGE_REGIME_PENALTY=8
DECISION_UNSTABLE_BTC_PENALTY=12
DECISION_MIN_TIMEFRAME_AGREEMENT=3


# DYNAMIC POSITION MANAGER v0.8.0
POSITION_INTELLIGENCE_ENABLED=true
POSITION_INTELLIGENCE_POLL_SECONDS=20

# SHADOW: только рекомендации, никаких изменений ордеров.
