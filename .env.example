PAPER_SLIPPAGE_PERCENT=0.03
PAPER_PRICE_POLL_SECONDS=10
MAX_POSITIONS=2

RISK_PER_TRADE_PERCENT=0.5
MAX_LEVERAGE=3
MIN_RISK_REWARD=2.0
TP1_R=1.0
TP1_CLOSE_PERCENT=35
TP2_R=2.0
TP2_CLOSE_PERCENT=35
RUNNER_PERCENT=30
BREAKEVEN_BUFFER_PERCENT=0.03
TRAILING_ATR_MULTIPLIER=1.8

AUTO_SCAN_ON_START=false
SCAN_INTERVAL_SECONDS=300
MIN_24H_TURNOVER_USDT=50000000
MAX_SPREAD_PERCENT=0.12
MAX_DEEP_CANDIDATES=10
MAX_AI_CANDIDATES=3
MAX_SIGNALS_PER_CYCLE=3
SIGNAL_COOLDOWN_MINUTES=60
SYMBOL_WHITELIST=BTC_USDT,ETH_USDT,SOL_USDT,LINK_USDT,XRP_USDT,BNB_USDT,ADA_USDT,DOGE_USDT,AVAX_USDT,SUI_USDT,TRX_USDT,TON_USDT,NEAR_USDT,APT_USDT,ARB_USDT,OP_USDT,INJ_USDT,SEI_USDT
MIN_SIGNAL_SCORE_PAPER=70
MIN_SIGNAL_SCORE_CONFIRM=80

DATABASE_PATH=./data/trader.db
LIVE_DATABASE_PATH=./data/live_trader.db
LOG_LEVEL=INFO
TIMEZONE=Europe/Moscow


# AI SCANNER PRO v0.5.0
SCANNER_TIMEFRAMES=Min5,Min15,Min60,Hour4
SCANNER_PRIMARY_TIMEFRAME=Min15
SCANNER_BTC_CONTEXT_ENABLED=true
SCANNER_MARKET_REGIME_ENABLED=true
SCANNER_MIN_HISTORY_BARS=220
SCANNER_MAX_PARALLEL_REQUESTS=4
SCANNER_REQUIRE_VOLUME_CONFIRMATION=false
SCANNER_MIN_RELATIVE_VOLUME=0.80
SCANNER_MIN_ATR_PERCENT=0.20
SCANNER_MAX_ATR_PERCENT=8.00
SCANNER_AI_ONLY_TOP_N=3
SCANNER_SIGNAL_EXPIRATION_SECONDS=180


# PORTFOLIO MANAGER v0.6.0
PORTFOLIO_MANAGER_ENABLED=true
PORTFOLIO_MAX_TOTAL_RISK_PERCENT=0.50
PORTFOLIO_MAX_SAME_DIRECTION_RISK_PERCENT=0.35
PORTFOLIO_MAX_GROUP_RISK_PERCENT=0.25
